{
  "version": 1,
  "defaults": {
    "timeout": 540,
    "outputDir": "./agents/counselors",
    "readOnly": "bestEffort",
    "maxContextKb": 50,
    "maxParallel": 4
  },
  "tools": {
    "claude-opus": {
      "binary": "claude",
      "adapter": "claude",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": [
        "--model",
        "opus"
      ]
    },
    "claude-opus-max": {
      "binary": "claude",
      "adapter": "claude",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": [
        "--model",
        "opus",
        "--effort",
        "max"
      ],
      "timeout": 900
    },
    "claude-sonnet": {
      "binary": "claude",
      "adapter": "claude",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": [
        "--model",
        "sonnet"
      ]
    },
    "claude-haiku": {
      "binary": "claude",
      "adapter": "claude",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": [
        "--model",
        "haiku"
      ]
    },
    "codex-5.5-medium": {
      "binary": "codex",
      "adapter": "codex",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": [
        "-m",
        "gpt-5.5",
        "-c",
        "model_reasoning_effort=medium"
      ],
      "timeout": 900
    },
    "codex-5.5-high": {
      "binary": "codex",
      "adapter": "codex",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": [
        "-m",
        "gpt-5.5",
        "-c",
        "model_reasoning_effort=high"
      ],
      "timeout": 900
    },
    "codex-5.5-xhigh": {
      "binary": "codex",
      "adapter": "codex",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": [
        "-m",
        "gpt-5.5",
        "-c",
        "model_reasoning_effort=xhigh"
      ],
      "timeout": 900
    },
    "codex-5.4-mini": {
      "binary": "codex",
      "adapter": "codex",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": [
        "-m",
        "gpt-5.4-mini",
        "-c",
        "model_reasoning_effort=medium"
      ],
      "timeout": 900
    },
    "agy": {
      "binary": "agy",
      "adapter": "custom",
      "readOnly": {
        "level": "bestEffort"
      },
      "extraFlags": [
        "--print-timeout",
        "10m",
        "-p"
      ],
      "timeout": 900
    }
  },
  "groups": {
    "quick": [
      "claude-haiku",
      "codex-5.4-mini",
      "agy"
    ],
    "default": [
      "claude-sonnet",
      "codex-5.5-high",
      "agy"
    ],
    "deep": [
      "claude-opus-max",
      "codex-5.5-xhigh",
      "agy"
    ]
  }
}
